{
  "version": 2,
  "functions": {
    "api/social-audit.js":    { "maxDuration": 60 },
    "api/social-section1.js": { "maxDuration": 15 },
    "api/social-section2.js": { "maxDuration": 15 },
    "api/social-section3.js": { "maxDuration": 15 },
    "api/social-section4.js": { "maxDuration": 15 },
    "api/social-section5.js": { "maxDuration": 15 }
  },
  "headers": [
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" }
      ]
    }
  ],
  "routes": [
    { "src": "/api/video-pitch", "dest": "/api/pitch-v2" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/frontend/$1" }
  ]
}
